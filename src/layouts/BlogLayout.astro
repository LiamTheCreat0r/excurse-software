---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  heroImage?: string;
}

const { title, description, pubDate, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description}>
  {heroImage && (
    <div class="blog-hero">
      <img src={heroImage} alt={title} />
    </div>
  )}
  <article class="blog-post">
    <div class="blog-header">
      {pubDate && <time datetime={pubDate.toISOString()}>{pubDate.toDateString()}</time>}
      <h1>{title}</h1>
      {description && <p class="blog-description">{description}</p>}
    </div>
    <slot />
  </article>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;700&display=swap');

  body {
    font-family: 'Inter', system-ui, sans-serif !important;
    color: #e8e8e8 !important;
    background: #0a0a0a !important;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
  }

  .blog-hero {
    width: 100%;
    max-height: 400px;
    overflow: hidden;
    margin-bottom: 0;
  }

  .blog-hero img {
    width: 100%;
    height: 100%;
    max-height: 400px;
    object-fit: cover;
    display: block;
  }

  .blog-post {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
  }

  .blog-header {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #222;
  }

  .blog-header time {
    display: inline-block;
    font-size: 0.8rem;
    color: #a94141;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .blog-header h1 {
    font-family: 'Anton', sans-serif;
    font-size: 2.5rem;
    color: #e8e8e8;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .blog-description {
    color: #888;
    font-size: 1.1rem;
    line-height: 1.6;
    margin: 0;
  }

  .blog-post time {
    display: block;
    font-size: 0.85rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #222;
  }

  .blog-post :global(h1) {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    color: #a94141;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 2rem;
  }

  .blog-post :global(h2),
  .blog-post :global(h3),
  .blog-post :global(h4) {
    font-family: 'Anton', sans-serif;
    color: #a94141;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 2rem 0 1rem;
  }

  .blog-post :global(p) {
    color: #aaa;
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .blog-post :global(a) {
    color: #a94141;
    text-decoration: none;
    transition: color 0.2s;
  }

  .blog-post :global(a:hover) {
    color: #e8e8e8;
  }

  .blog-post :global(code) {
    background: #1a1a1a;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .blog-post :global(pre) {
    background: #1a1a1a;
    padding: 1.5rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .blog-post :global(pre code) {
    background: none;
    padding: 0;
  }

  .blog-post :global(ul),
  .blog-post :global(ol) {
    color: #aaa;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-post :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .blog-post :global(blockquote) {
    border-left: 3px solid #a94141;
    padding-left: 1.5rem;
    margin: 1.5rem 0;
    color: #888;
    font-style: italic;
  }

  .blog-post :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.5rem 0;
  }

  .blog-post :global(hr) {
    border: none;
    border-top: 1px solid #222;
    margin: 2rem 0;
  }
</style>
