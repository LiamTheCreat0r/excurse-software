---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import logo from '../assets/images/logos/excurse-software-logo.png';
import logoAlternate from '../assets/images/logos/excurse-software-logo-alternate.png';
import babelCartridge from '../assets/images/cartridges/babel-adventure-cartridge.png';
import parabellumCartridge from '../assets/images/cartridges/parabellum-rain-cartridge.png';
import endhellCartridge from '../assets/images/cartridges/endhell-cartridge.png';
import spectraCollabCartridge from '../assets/images/cartridges/spectra-collab-cartridge.png';

import babelCover from '../assets/images/game-covers/babel-adventure.png';
import parabellumCover from '../assets/images/game-covers/parabellum-rain.png';
import endhellCover from '../assets/images/game-covers/endhell.png';
import spectraCollabCover from '../assets/images/game-covers/spectra-collab.png';
import instagramIcon from '../assets/images/socials/Instagram_logo.png';
import tiktokIcon from '../assets/images/socials/Tiktok_icon.png';
import twitterIcon from '../assets/images/socials/Twitter_icon.png';
import youtubeIcon from '../assets/images/socials/Youtube_icon.png';
import kofiIcon from '../assets/images/socials/Kofi_icon.png';
---

<BaseLayout title="Excurse Software" description="A video game studio">
  <nav id="menu-bar">
    <div class="menu-inner">
      <a href="#" class="menu-logo-link">
        <Image src={logoAlternate} alt="Excurse Software" class="menu-logo" height={32} loading="eager" quality={90} />
        <span class="menu-brand">Excurse Software</span>
      </a>
      <div class="menu-links">
        <a href="#studio" class="menu-link">The Studio</a>
        <a href="#games" class="menu-link">Our Games</a>
        <a href="#team" class="menu-link">The Team</a>
      </div>
      <button class="menu-toggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <section id="studio" class="section studio">
    <div class="studio-content">
      <div class="studio-logo">
        <Image src={logo} alt="Excurse Software" class="studio-logo-img" width={180} loading="eager" quality={90} />
      </div>
      <div class="studio-text">
        <h1>Excurse Software</h1>
        <p class="tagline">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
      </div>
    </div>
  </section>

  <section id="games" class="section games">
    <div class="games-cover-bg">
      <div class="cover-layer" id="cover-layer-1"></div>
      <div class="cover-layer" id="cover-layer-2"></div>
    </div>
    <h2>Our Games</h2>
    <div class="game-info">
      <h3 class="game-title" id="game-title">Endhell</h3>
      <div class="game-info-right">
        <p class="game-desc" id="game-desc">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
        <a href="#" class="game-btn">Know More</a>
      </div>
    </div>
    <div class="games-content">
      <div class="cartridge-wrap" data-cover="endhell">
        <Image src={endhellCartridge} alt="Endhell" class="cartridge-img" width={180} loading="lazy" quality={90} />
        <p class="device-label">Endhell</p>
      </div>
      <div class="cartridge-wrap" data-cover="spectra-collab">
        <Image src={spectraCollabCartridge} alt="Spectra Collab" class="cartridge-img" width={180} loading="lazy" quality={90} />
        <p class="device-label">Spectra Collab</p>
      </div>
      <div class="cartridge-wrap" data-cover="parabellum">
        <Image src={parabellumCartridge} alt="Parabellum Rain" class="cartridge-img" width={180} loading="lazy" quality={90} />
        <p class="device-label">Parabellum Rain</p>
      </div>
      <div class="cartridge-wrap" data-cover="babel">
        <Image src={babelCartridge} alt="Babel Adventure" class="cartridge-img" width={180} loading="lazy" quality={90} />
        <p class="device-label">Babel Adventure</p>
      </div>
    </div>
  </section>

  <section id="team" class="section team">
    <h2>The Team</h2>
    <div class="team-grid">
      <div class="team-member">
        <div class="member-icon">
          <svg viewBox="0 0 80 80" width="100" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="40" cy="28" r="14" />
            <path d="M14 72c0-14 12-26 26-26s26 12 26 26" />
          </svg>
        </div>
        <h3>John Doe</h3>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      </div>
      <div class="team-member">
        <div class="member-icon">
          <svg viewBox="0 0 80 80" width="100" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="40" cy="28" r="14" />
            <path d="M14 72c0-14 12-26 26-26s26 12 26 26" />
          </svg>
        </div>
        <h3>Jane Smith</h3>
        <p>Sed do eiusmod tempor incididunt ut labore et dolore.</p>
      </div>
      <div class="team-member">
        <div class="member-icon">
          <svg viewBox="0 0 80 80" width="100" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="40" cy="28" r="14" />
            <path d="M14 72c0-14 12-26 26-26s26 12 26 26" />
          </svg>
        </div>
        <h3>Alex Brown</h3>
        <p>Magna aliqua ut enim ad minim veniam, quis nostrud.</p>
      </div>
    </div>
  </section>

  <footer id="footer">
    <div class="footer-inner">
      <div class="footer-socials">
        <a class="social-link" aria-label="Twitter">
          <Image src={twitterIcon} alt="Twitter" width={28} height={28} loading="lazy" quality={90} />
        </a>
        <a class="social-link" aria-label="Instagram">
          <Image src={instagramIcon} alt="Instagram" width={28} height={28} loading="lazy" quality={90} />
        </a>
        <a class="social-link" aria-label="TikTok">
          <Image src={tiktokIcon} alt="TikTok" width={28} height={28} loading="lazy" quality={90} />
        </a>
        <a class="social-link" aria-label="YouTube">
          <Image src={youtubeIcon} alt="YouTube" width={28} height={28} loading="lazy" quality={90} />
        </a>
      </div>
      <p class="footer-copy">&copy; 2026 Liam Valty - Excurse Software. All rights reserved.</p>
    </div>
  </footer>

  <a class="kofi-button" aria-label="Support us on Ko-fi">
    <Image src={kofiIcon} alt="Ko-fi" width={24} height={24} loading="lazy" quality={90} />
    <span>Support Us</span>
  </a>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;700&display=swap');

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif !important;
    color: #e8e8e8 !important;
    background: #0a0a0a !important;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
  }

  #menu-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #a94141;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    will-change: transform;
  }

  #menu-bar.visible {
    transform: translateY(0);
  }

  .menu-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 0.6rem 2rem;
  }

  .menu-logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    line-height: 0;
    text-decoration: none;
  }

  .menu-logo {
    height: 32px;
    width: auto;
    transition: opacity 0.2s;
  }

  .menu-logo:hover {
    opacity: 0.7;
  }

  .menu-brand {
    font-family: 'Anton', sans-serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #e8e8e8;
    transition: opacity 0.2s;
  }

  .menu-logo-link:hover .menu-brand {
    opacity: 0.7;
  }

  .menu-links {
    display: flex;
    gap: 2.5rem;
    margin-left: auto;
  }

  .menu-link {
    color: #a94141;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.2s;
  }

  .menu-link:hover {
    color: #e8e8e8;
  }

  .section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    position: relative;
  }

  .studio {
    background: radial-gradient(ellipse at 50% 0%, #1a0a0a 0%, #0a0a0a 70%);
  }

  .studio-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    max-width: 1200px;
    width: 100%;
  }

  .studio-logo-img {
    filter: drop-shadow(0 0 30px rgba(169, 65, 65, 0.3));
  }

  .studio-text h1 {
    font-family: 'Anton', sans-serif;
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: #a94141;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tagline {
    font-size: 1rem;
    color: #888;
    max-width: 440px;
    line-height: 1.8;
  }

  .games {
    background: radial-gradient(ellipse at 50% 50%, #111 0%, #0a0a0a 70%);
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    overflow: hidden;
  }

  .games-cover-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .cover-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .cover-layer.active {
    opacity: 0.6;
  }

  .games h2 {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a94141;
    position: relative;
    z-index: 1;
  }

  .game-info {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    position: relative;
    z-index: 1;
    margin-bottom: 2rem;
    padding: 2rem 3rem;
    background: rgba(0, 0, 0, 0.7);
    border-radius: 8px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }

  .game-title {
    font-family: 'Anton', sans-serif;
    font-size: 2.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #e8e8e8;
    white-space: nowrap;
    margin: 0;
    padding-right: 3rem;
    border-right: 2px solid #a94141;
  }

  .game-info-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .game-desc {
    font-size: 1rem;
    color: #aaa;
    line-height: 1.6;
    margin: 0;
    max-width: 450px;
  }

  .game-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: transparent;
    border: 1px solid #a94141;
    color: #a94141;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 4px;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .game-btn:hover {
    background: #a94141;
    color: #fff;
  }

  .games-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    max-width: 1200px;
    width: 100%;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
    margin-top: auto;
    padding-bottom: 2rem;
  }

  .cartridge-wrap {
    text-align: center;
    cursor: pointer;
  }

.cartridge-img {
    width: 180px;
    height: auto;
    display: block;
    transition: transform 0.3s ease, filter 0.3s ease;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.6));
  }

  .cartridge-wrap.selected .cartridge-img {
    transform: translateY(-25px);
    filter: drop-shadow(0 12px 30px rgba(169, 65, 65, 0.35));
  }

  .cartridge-img:hover {
    transform: scale(1.1) translateY(-30px);
    filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.5));
  }

  .device-label {
    margin-top: 1.2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #666;
  }

  .team {
    background: radial-gradient(ellipse at 50% 100%, #1a0a0a 0%, #0a0a0a 70%);
    flex-direction: column;
    gap: 3rem;
  }

  .team h2 {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a94141;
  }

  .team-grid {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .team-member {
    text-align: center;
    max-width: 220px;
    padding: 2rem 1.5rem;
    border: 1px solid #222;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.3s;
  }

  .team-member:hover {
    border-color: #a94141;
  }

  .member-icon svg {
    color: #a94141;
    margin-bottom: 1rem;
  }

  .team-member h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #e8e8e8;
  }

  .team-member p {
    color: #666;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  #footer {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 3rem 2rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-socials {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
  }

  .social-link:hover {
    opacity: 0.6;
  }

  .social-link img {
    height: 28px;
    width: auto;
  }

  .footer-copy {
    color: #444;
    font-size: 0.8rem;
  }

  .kofi-button {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: #a94141;
    color: #fff;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(169, 65, 65, 0.4);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .kofi-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(169, 65, 65, 0.5);
  }

  .kofi-button img {
    height: 24px;
    width: auto;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    flex-direction: column;
    gap: 5px;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #e8e8e8;
    border-radius: 1px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 768px) {
    .menu-inner {
      gap: 1rem;
      padding: 0.6rem 1rem;
    }

    .menu-toggle {
      display: flex;
      margin-left: auto;
    }

    .menu-links {
      position: fixed;
      top: 56px;
      left: 0;
      width: 100%;
      flex-direction: column;
      align-items: center;
      background: rgba(10, 10, 10, 0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid #a94141;
      padding: 1.5rem;
      gap: 1.25rem;
      margin-left: 0;
      transform: translateY(-110%);
      opacity: 0;
      pointer-events: none;
      transition: transform 0.3s ease, opacity 0.3s ease;
    }

    .menu-links.open {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .menu-link {
      font-size: 0.9rem;
    }

    .studio-content {
      flex-direction: column;
      text-align: center;
    }

    .studio-text h1 {
      font-size: 2.5rem;
    }

    .tagline {
      max-width: 100%;
    }

    .games-content {
      gap: 3rem;
    }
  }

  @media (max-width: 480px) {
    .menu-links {
      padding: 1rem;
      gap: 0.75rem;
    }
  }
</style>

<script>
  const menuBar = document.getElementById('menu-bar');
  const studio = document.getElementById('studio');

  const observer = new IntersectionObserver(
    ([entry]) => {
      menuBar.classList.toggle('visible', !entry.isIntersecting);
    },
    { threshold: 0 }
  );

  if (studio) observer.observe(studio);

  document.querySelectorAll('.menu-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(link.getAttribute('href'));
      if (target) target.scrollIntoView({ behavior: 'smooth' });
      document.querySelector('.menu-toggle')?.classList.remove('active');
      document.querySelector('.menu-links')?.classList.remove('open');
    });
  });

  document.querySelector('.menu-toggle')?.addEventListener('click', () => {
    document.querySelector('.menu-toggle')?.classList.toggle('active');
    document.querySelector('.menu-links')?.classList.toggle('open');
  });

  const gameInfo = {
    endhell: { title: 'Endhell', desc: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.' },
    'spectra-collab': { title: 'Spectra Collab', desc: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.' },
    parabellum: { title: 'Parabellum Rain', desc: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.' },
    babel: { title: 'Babel Adventure', desc: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.' }
  };

  const covers = {
    babel: 'url(/excurse-software/images/game-covers/babel-adventure.png)',
    parabellum: 'url(/excurse-software/images/game-covers/parabellum-rain.png)',
    endhell: 'url(/excurse-software/images/game-covers/endhell.png)',
    'spectra-collab': 'url(/excurse-software/images/game-covers/spectra-collab.png)'
  };

  const gameTitleEl = document.getElementById('game-title');
  const gameDescEl = document.getElementById('game-desc');
  const gamesSection = document.getElementById('games');
  const layer1 = document.getElementById('cover-layer-1');
  const layer2 = document.getElementById('cover-layer-2');
  const cartridges = document.querySelectorAll('.cartridge-wrap');
  let selectedCover = null;
  let activeLayer = 1;

  function updateGameInfo(key) {
    if (gameInfo[key]) {
      gameTitleEl.textContent = gameInfo[key].title;
      gameDescEl.textContent = gameInfo[key].desc;
    }
  }

  if (cartridges.length > 0) {
    const firstCartridge = cartridges[0];
    selectedCover = firstCartridge.dataset.cover;
    firstCartridge.classList.add('selected');
    setCover(covers[selectedCover]);
    updateGameInfo(selectedCover);
  }

  function setCover(coverUrl) {
    if (activeLayer === 1) {
      layer2.style.backgroundImage = coverUrl;
      layer1.classList.remove('active');
      layer2.classList.add('active');
      activeLayer = 2;
    } else {
      layer1.style.backgroundImage = coverUrl;
      layer2.classList.remove('active');
      layer1.classList.add('active');
      activeLayer = 1;
    }
  }

  function clearCover() {
    if (activeLayer === 1) {
      layer1.classList.remove('active');
    } else {
      layer2.classList.remove('active');
    }
  }

  cartridges.forEach((cartridge) => {
    const coverKey = cartridge.dataset.cover;
    const coverUrl = covers[coverKey];

    cartridge.addEventListener('mouseenter', () => {
      cartridges.forEach(c => c.classList.remove('selected'));
      selectedCover = coverKey;
      cartridge.classList.add('selected');
      setCover(coverUrl);
      updateGameInfo(coverKey);
    });
  });
</script>
