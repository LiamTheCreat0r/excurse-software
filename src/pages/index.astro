---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import logo from '../assets/images/logos/excurse-software-logo.png';
import logoAlternate from '../assets/images/logos/excurse-software-logo-alternate.png';
import babelCartridge from '../assets/images/cartridges/babel-adventure-cartridge.png';
import parabellumCartridge from '../assets/images/cartridges/parabellum-rain-cartridge.png';
import endhellCartridge from '../assets/images/cartridges/endhell-cartridge.png';
import spectraCollabCartridge from '../assets/images/cartridges/spectra-collab-cartridge.png';

import babelCover from '../assets/images/game-covers/babel-adventure.png';
import parabellumCover from '../assets/images/game-covers/parabellum-rain.png';
import endhellCover from '../assets/images/game-covers/endhell.png';
import spectraCollabCover from '../assets/images/game-covers/spectra-collab.png';
import instagramIcon from '../assets/images/socials/Instagram_logo.png';
import tiktokIcon from '../assets/images/socials/Tiktok_icon.png';
import twitterIcon from '../assets/images/socials/Twitter_icon.png';
import youtubeIcon from '../assets/images/socials/Youtube_icon.png';
import kofiIcon from '../assets/images/socials/Kofi_icon.png';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Excurse Software" description="A video game studio">
  <nav id="menu-bar">
    <div class="menu-inner">
      <a href="#" class="menu-logo-link">
        <Image src={logoAlternate} alt="Excurse Software" class="menu-logo" height={32} loading="eager" quality={90} />
        <span class="menu-brand">Excurse Software</span>
      </a>
      <div class="menu-links">
        <a href="#studio" class="menu-link">The Studio</a>
        <a href="#games" class="menu-link">Our Games</a>
        <a href="#team" class="menu-link">The Team</a>
        <a href="#blog" class="menu-link">Blog</a>
      </div>
      <button class="menu-toggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <section id="studio" class="section studio">
    <div class="studio-video-bg">
      <video muted loop playsinline class="bg-video active">
        <source src="/excurse-software/videos/babel-1.webm" type="video/webm" />
      </video>
      <video muted loop playsinline class="bg-video">
        <source src="/excurse-software/videos/babel-2.webm" type="video/webm" />
      </video>
      <video muted loop playsinline class="bg-video">
        <source src="/excurse-software/videos/babel-3.webm" type="video/webm" />
      </video>
      <video muted loop playsinline class="bg-video">
        <source src="/excurse-software/videos/parabellum-rain1.webm" type="video/webm" />
      </video>
      <video muted loop playsinline class="bg-video">
        <source src="/excurse-software/videos/parabellum-rain2.webm" type="video/webm" />
      </video>
      <video muted loop playsinline class="bg-video">
        <source src="/excurse-software/videos/parabellum-rain3.webm" type="video/webm" />
      </video>
      <video muted loop playsinline class="bg-video">
        <source src="/excurse-software/videos/spectra-collab1.webm" type="video/webm" />
      </video>
      <video muted loop playsinline class="bg-video">
        <source src="/excurse-software/videos/spectra-collab2.webm" type="video/webm" />
      </video>
    </div>
    <div class="studio-content">
      <div class="studio-logo">
        <Image src={logo} alt="Excurse Software" class="studio-logo-img" width={140} loading="eager" quality={90} />
      </div>
      <div class="studio-text">
        <h1>Excurse Software</h1>
        <p class="tagline">A team of passionate artists, nothing more, nothing less.</p>
      </div>
    </div>
  </section>

  <section id="games" class="section games">
    <h2>Our Games</h2>
    <div class="games-main">
      <div class="games-cover-bg">
        <div class="cover-layer" id="cover-layer-1"></div>
        <div class="cover-layer" id="cover-layer-2"></div>
      </div>
      <div class="game-info">
        <h3 class="game-title" id="game-title">Endhell</h3>
        <div class="game-info-right">
          <p class="game-desc" id="game-desc">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
          <a href="#" class="game-btn">Know More</a>
        </div>
      </div>
    <div class="games-content">
      <div class="cartridge-wrap" data-cover="endhell">
        <Image src={endhellCartridge} alt="Endhell" class="cartridge-img" width={140} loading="lazy" quality={90} />
        <p class="device-label">Endhell</p>
      </div>
      <div class="cartridge-wrap" data-cover="spectra-collab">
        <Image src={spectraCollabCartridge} alt="Spectra Collab" class="cartridge-img" width={140} loading="lazy" quality={90} />
        <p class="device-label">Spectra Collab</p>
      </div>
      <div class="cartridge-wrap" data-cover="parabellum">
        <Image src={parabellumCartridge} alt="Parabellum Rain" class="cartridge-img" width={140} loading="lazy" quality={90} />
        <p class="device-label">Parabellum Rain</p>
      </div>
      <div class="cartridge-wrap" data-cover="babel">
        <Image src={babelCartridge} alt="Babel Adventure" class="cartridge-img" width={140} loading="lazy" quality={90} />
        <p class="device-label">Babel Adventure</p>
      </div>
    </div>
  </section>

  <section id="team" class="section team">
    <h2>The Team</h2>
    <div class="team-grid">
      <div class="team-member">
        <div class="member-icon">
          <svg viewBox="0 0 80 80" width="100" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="40" cy="28" r="14" />
            <path d="M14 72c0-14 12-26 26-26s26 12 26 26" />
          </svg>
        </div>
        <h3>John Doe</h3>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      </div>
      <div class="team-member">
        <div class="member-icon">
          <svg viewBox="0 0 80 80" width="100" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="40" cy="28" r="14" />
            <path d="M14 72c0-14 12-26 26-26s26 12 26 26" />
          </svg>
        </div>
        <h3>Jane Smith</h3>
        <p>Sed do eiusmod tempor incididunt ut labore et dolore.</p>
      </div>
      <div class="team-member">
        <div class="member-icon">
          <svg viewBox="0 0 80 80" width="100" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="40" cy="28" r="14" />
            <path d="M14 72c0-14 12-26 26-26s26 12 26 26" />
          </svg>
        </div>
        <h3>Alex Brown</h3>
        <p>Magna aliqua ut enim ad minim veniam, quis nostrud.</p>
      </div>
    </div>
  </section>

  <section id="blog" class="section blog">
    <h2>Blog</h2>
    <div class="blog-grid">
      {
        posts.map((post) => (
          <article class="blog-card">
            <a href={`/excurse-software/blog/${post.id}`} class="blog-card-link">
              {post.data.heroImage && (
                <img src={post.data.heroImage} alt={post.data.title} class="blog-thumbnail" loading="lazy" />
              )}
              <div class="blog-card-content">
                <h3>{post.data.title}</h3>
                <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toDateString()}</time>
                <p>{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="blog-tags">
                    {post.data.tags.map((tag) => <span class="blog-tag">{tag}</span>)}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <footer id="footer">
    <div class="footer-inner">
      <div class="footer-socials">
        <a class="social-link" aria-label="Twitter" href="https://x.com/excursesoftware" target="_blank" rel="noopener noreferrer">
          <Image src={twitterIcon} alt="Twitter" width={56} height={56} loading="lazy" quality={100} format="png" />
        </a>
        <a class="social-link" aria-label="Instagram" href="https://www.instagram.com/excurse_software/" target="_blank" rel="noopener noreferrer">
          <Image src={instagramIcon} alt="Instagram" width={56} height={56} loading="lazy" quality={100} format="png" />
        </a>
        <a class="social-link" aria-label="TikTok" href="https://www.tiktok.com/@excurse_software" target="_blank" rel="noopener noreferrer">
          <Image src={tiktokIcon} alt="TikTok" width={56} height={56} loading="lazy" quality={100} format="png" />
        </a>
        <a class="social-link" aria-label="YouTube">
          <Image src={youtubeIcon} alt="YouTube" width={56} height={56} loading="lazy" quality={100} format="png" />
        </a>
      </div>
      <p class="footer-copy">&copy; 2026 Liam Valty - Excurse Software. All rights reserved.</p>
    </div>
  </footer>

  <a class="kofi-button" aria-label="Support us on Ko-fi">
    <Image src={kofiIcon} alt="Ko-fi" width={24} height={24} loading="lazy" quality={90} />
    <span>Support Us</span>
  </a>
</BaseLayout>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;700&display=swap');

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', system-ui, sans-serif !important;
    color: #e8e8e8 !important;
    background: #0a0a0a !important;
    background-image: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0, 0, 0, 0.15) 2px,
      rgba(0, 0, 0, 0.15) 4px
    );
  }

  #menu-bar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #a94141;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    will-change: transform;
  }

  #menu-bar.visible {
    transform: translateY(0);
  }

  .menu-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 0.6rem 2rem;
  }

  .menu-logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    line-height: 0;
    text-decoration: none;
  }

  .menu-logo {
    height: 32px;
    width: auto;
    transition: opacity 0.2s;
  }

  .menu-logo:hover {
    opacity: 0.7;
  }

  .menu-brand {
    font-family: 'Anton', sans-serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #e8e8e8;
    transition: opacity 0.2s;
  }

  .menu-logo-link:hover .menu-brand {
    opacity: 0.7;
  }

  .menu-links {
    display: flex;
    gap: 2.5rem;
    margin-left: auto;
  }

  .menu-link {
    color: #a94141;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: color 0.2s;
  }

  .menu-link:hover {
    color: #e8e8e8;
  }

  .section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    position: relative;
  }

  .studio {
    background: radial-gradient(ellipse at 50% 0%, #1a0a0a 0%, #0a0a0a 70%);
    overflow: hidden;
  }

  .studio-video-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .bg-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 1s ease;
    filter: blur(8px) brightness(0.6);
    transform: scale(1.1);
  }

  .bg-video.active {
    opacity: 0.4;
  }

  .studio-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    max-width: 1200px;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .studio-logo-img {
    filter: drop-shadow(0 0 30px rgba(169, 65, 65, 0.3));
  }

  .studio-text h1 {
    font-family: 'Anton', sans-serif;
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: #a94141;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .tagline {
    font-size: 1rem;
    color: #888;
    max-width: 440px;
    line-height: 1.8;
  }

.games {
    background: transparent;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .games-main {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    flex: 1;
    justify-content: center;
    gap: 2rem;
    padding: 3rem;
  }

  .games-cover-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .cover-layer {
    position: absolute;
    top: -10%;
    left: -10%;
    width: 120%;
    height: 120%;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 0.4s ease;
    transform: scale(0.8);
  }

  .cover-layer.active {
    opacity: 0.5;
    transform: scale(0.8);
  }

  .games h2 {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a94141;
    position: relative;
    z-index: 2;
    margin: 2rem 0;
  }

  .game-info {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    position: relative;
    z-index: 1;
    margin-bottom: 2rem;
    padding: 2rem 3rem;
    background: rgba(0, 0, 0, 0.7);
    border-radius: 8px;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .game-info.visible {
    opacity: 1;
  }

  .game-title {
    font-family: 'Anton', sans-serif;
    font-size: 2.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #e8e8e8;
    white-space: nowrap;
    margin: 0;
    padding-right: 3rem;
    border-right: 2px solid #a94141;
  }

  .game-info-right {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  .game-desc {
    font-size: 1rem;
    color: #aaa;
    line-height: 1.6;
    margin: 0;
    max-width: 450px;
  }

  .game-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: transparent;
    border: 1px solid #a94141;
    color: #a94141;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-radius: 4px;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .game-btn:hover {
    background: #a94141;
    color: #fff;
  }

  .games-content {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    max-width: 1200px;
    width: 100%;
    flex-wrap: wrap;
    position: relative;
    z-index: 1;
    margin-top: auto;
    padding-bottom: 2rem;
  }

.cartridge-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    width: 140px;
  }

 .cartridge-img {
    width: 140px;
    height: auto;
    display: block;
    transition: transform 0.3s ease, filter 0.3s ease;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.6));
  }

  .cartridge-wrap.selected .cartridge-img {
    transform: translateY(-25px) scale(1);
    filter: drop-shadow(0 12px 30px rgba(169, 65, 65, 0.35));
    position: relative;
    z-index: 1;
  }

  .cartridge-img:hover {
    transform: scale(1.1) translateY(-30px);
    filter: drop-shadow(0 16px 40px rgba(0, 0, 0, 0.5));
  }

  .device-label {
    margin-top: 1.2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #666;
    width: 140px;
    text-align: center;
    background: rgba(0, 0, 0, 0.4);
    padding: 0.4rem 0.2rem;
    border-radius: 10px;
    color: #fff;
  }

  .team {
    background: radial-gradient(ellipse at 50% 100%, #1a0a0a 0%, #0a0a0a 70%);
    flex-direction: column;
    gap: 3rem;
  }

  .team h2 {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a94141;
  }

  .team-grid {
    display: flex;
    gap: 4rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .team-member {
    text-align: center;
    max-width: 220px;
    padding: 2rem 1.5rem;
    border: 1px solid #222;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.3s;
  }

  .team-member:hover {
    border-color: #a94141;
  }

  .member-icon svg {
    color: #a94141;
    margin-bottom: 1rem;
  }

  .team-member h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #e8e8e8;
  }

  .team-member p {
    color: #666;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .blog {
    background: transparent;
    flex-direction: column;
    gap: 3rem;
  }

  .blog h2 {
    font-family: 'Anton', sans-serif;
    font-size: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a94141;
  }

  .blog-grid {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 1200px;
    width: 100%;
  }

  .blog-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid #222;
    border-radius: 8px;
    transition: border-color 0.3s, transform 0.3s;
    flex: 1 1 300px;
    max-width: 360px;
    overflow: hidden;
  }

  .blog-card:hover {
    border-color: #a94141;
    transform: translateY(-4px);
  }

  .blog-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .blog-thumbnail {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }

  .blog-card-content {
    padding: 1.5rem;
  }

  .blog-card-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #e8e8e8;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .blog-card-content time {
    display: block;
    font-size: 0.75rem;
    color: #666;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .blog-card-content p {
    color: #888;
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .blog-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .blog-tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #a94141;
    border: 1px solid #a94141;
    border-radius: 4px;
  }

  #footer {
    background: #0a0a0a;
    border-top: 1px solid #1a1a1a;
    padding: 3rem 2rem;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .footer-socials {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .social-link {
    display: flex;
    align-items: center;
    transition: transform 0.2s ease, opacity 0.2s;
  }

  .social-link:hover {
    opacity: 0.8;
    transform: scale(1.15);
  }

  .social-link img {
    height: 48px;
    width: auto;
  }

  .footer-copy {
    color: #444;
    font-size: 0.8rem;
  }

  .kofi-button {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.4rem;
    background: rgba(0, 0, 0, 0.7);
    color: #e8e8e8;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: 24px;
    border: 1px solid #a94141;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  }

  .kofi-button:hover {
    transform: translateY(-2px);
    background: rgba(169, 65, 65, 0.8);
  }

  .kofi-button img {
    height: 24px;
    width: auto;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    flex-direction: column;
    gap: 5px;
  }

  .menu-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #e8e8e8;
    border-radius: 1px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  @media (max-width: 768px) {
    .menu-inner {
